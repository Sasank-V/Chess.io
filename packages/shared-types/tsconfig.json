{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",

    "target": "ES2022",
    "module": "nodenext",
    "moduleResolution": "nodenext",

    "strict": true,
    "composite": true,

    "declaration": true,
    "declarationMap": true,

    "esModuleInterop": true,

    "sourceMap": true,

    "skipLibCheck": true
  },

  "include": ["src"]
}
