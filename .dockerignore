# -----------------------------------------------------------------------------
# Dependencies
# -----------------------------------------------------------------------------
**/node_modules
.pnpm-store

# -----------------------------------------------------------------------------
# Build outputs
# -----------------------------------------------------------------------------
**/dist
**/build
**/.turbo
**/.cache
**/.next
**/.vite
**/coverage

# -----------------------------------------------------------------------------
# TypeScript
# -----------------------------------------------------------------------------
**/*.tsbuildinfo

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
**/*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*

# -----------------------------------------------------------------------------
# Environment files
# -----------------------------------------------------------------------------
**/.env
**/.env.*
!**/.env.example

# -----------------------------------------------------------------------------
# Git
# -----------------------------------------------------------------------------
.git
.gitignore
.gitattributes

# -----------------------------------------------------------------------------
# IDEs / Editors
# -----------------------------------------------------------------------------
.vscode
.idea
*.swp
*.swo

# -----------------------------------------------------------------------------
# Operating System
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db

# -----------------------------------------------------------------------------
# Documentation (optional)
# Uncomment if not required in image
# -----------------------------------------------------------------------------
# README.md
# ARCHITECTURE.md
# SETUP_GUIDE.md
# Ideas.txt

# -----------------------------------------------------------------------------
# Docker
# Prevent copying compose files into images
# -----------------------------------------------------------------------------
docker-compose*.yml

# -----------------------------------------------------------------------------
# Tests (optional)
# Uncomment if tests are not required inside container
# -----------------------------------------------------------------------------
# **/__tests__
# **/*.test.ts
# **/*.spec.ts

# -----------------------------------------------------------------------------
# Local development artifacts
# -----------------------------------------------------------------------------
**/.eslintcache
**/.parcel-cache

# -----------------------------------------------------------------------------
# Vercel
# -----------------------------------------------------------------------------
.vercel

# -----------------------------------------------------------------------------
# Temporary files
# -----------------------------------------------------------------------------
tmp
temp
*.tmp