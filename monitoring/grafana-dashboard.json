{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "10.0.0"
    },
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": "1.0.0"
    },
    {
      "type": "panel",
      "id": "timeseries",
      "name": "Time series",
      "version": ""
    },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "row", "name": "Row", "version": "" }
  ],
  "id": null,
  "uid": "game-platform-overview",
  "title": "Game Platform - Service Overview",
  "description": "Unified dashboard for api-service, ws-service, and persistence-service (Node.js microservices)",
  "tags": ["nodejs", "game-platform", "microservices"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "graphTooltip": 1,
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "query": "prometheus",
        "current": {},
        "label": "Prometheus",
        "hide": 0
      },
      {
        "name": "service",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "query": "label_values(process_start_time_seconds, service)",
        "current": { "text": "All", "value": "$__all" },
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "refresh": 2,
        "sort": 1,
        "label": "Service"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Fleet Overview",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Process Uptime",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "targets": [
        {
          "expr": "time() - process_start_time_seconds{service=~\"$service\"}",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s", "color": { "mode": "palette-classic" } },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "graphMode": "none",
        "colorMode": "value"
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "CPU Usage Rate (user + system)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 9, "x": 6, "y": 1 },
      "targets": [
        {
          "expr": "rate(process_cpu_seconds_total{service=~\"$service\"}[5m])",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit" }, "overrides": [] }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Resident Memory (RSS)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 9, "x": 15, "y": 1 },
      "targets": [
        {
          "expr": "process_resident_memory_bytes{service=~\"$service\"}",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Event Loop Lag (mean / p99)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 9 },
      "targets": [
        {
          "expr": "nodejs_eventloop_lag_mean_seconds{service=~\"$service\"}",
          "legendFormat": "{{service}} mean",
          "refId": "A"
        },
        {
          "expr": "nodejs_eventloop_lag_p99_seconds{service=~\"$service\"}",
          "legendFormat": "{{service}} p99",
          "refId": "B"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Node.js Heap Used / Total",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 9 },
      "targets": [
        {
          "expr": "nodejs_heap_size_used_bytes{service=~\"$service\"}",
          "legendFormat": "{{service}} used",
          "refId": "A"
        },
        {
          "expr": "nodejs_heap_size_total_bytes{service=~\"$service\"}",
          "legendFormat": "{{service}} total",
          "refId": "B"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "GC Time Rate by Kind",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 9 },
      "targets": [
        {
          "expr": "rate(nodejs_gc_duration_seconds_sum{service=~\"$service\"}[5m])",
          "legendFormat": "{{service}} - {{kind}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Open File Descriptors",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 17 },
      "targets": [
        {
          "expr": "process_open_fds{service=~\"$service\"}",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "none" }, "overrides": [] }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Active Handles / Resources",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 17 },
      "targets": [
        {
          "expr": "nodejs_active_handles_total{service=~\"$service\"}",
          "legendFormat": "{{service}} handles",
          "refId": "A"
        },
        {
          "expr": "nodejs_active_resources_total{service=~\"$service\"}",
          "legendFormat": "{{service}} resources",
          "refId": "B"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "none" }, "overrides": [] }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "External Memory",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 17 },
      "targets": [
        {
          "expr": "nodejs_external_memory_bytes{service=~\"$service\"}",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] }
    },

    {
      "id": 20,
      "type": "row",
      "title": "api-service (HTTP API)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 21,
      "type": "timeseries",
      "title": "HTTP Request Rate (by route/status)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 24 },
      "targets": [
        {
          "expr": "sum by (route, method, status) (rate(api_http_requests_total{service=\"api-service\"}[5m]))",
          "legendFormat": "{{method}} {{route}} [{{status}}]",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] }
    },
    {
      "id": 22,
      "type": "timeseries",
      "title": "HTTP Request Duration (avg)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 24 },
      "targets": [
        {
          "expr": "sum by (route) (rate(api_http_request_duration_seconds_sum{service=\"api-service\"}[5m])) / sum by (route) (rate(api_http_request_duration_seconds_count{service=\"api-service\"}[5m]))",
          "legendFormat": "{{route}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] }
    },
    {
      "id": 23,
      "type": "timeseries",
      "title": "Active HTTP Requests",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 24 },
      "targets": [
        {
          "expr": "api_http_active_requests{service=\"api-service\"}",
          "legendFormat": "active requests",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "none" }, "overrides": [] }
    },
    {
      "id": 24,
      "type": "stat",
      "title": "Games / Moves / Auth (totals)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 32 },
      "targets": [
        {
          "expr": "api_games_created_total{service=\"api-service\"}",
          "legendFormat": "Games created",
          "refId": "A"
        },
        {
          "expr": "api_games_finished_total{service=\"api-service\"}",
          "legendFormat": "Games finished",
          "refId": "B"
        },
        {
          "expr": "api_moves_saved_total{service=\"api-service\"}",
          "legendFormat": "Moves saved",
          "refId": "C"
        },
        {
          "expr": "api_users_registered_total{service=\"api-service\"}",
          "legendFormat": "Users registered",
          "refId": "D"
        },
        {
          "expr": "api_auth_google_login_total{service=\"api-service\"}",
          "legendFormat": "Google logins",
          "refId": "E"
        },
        {
          "expr": "api_auth_failed_login_total{service=\"api-service\"}",
          "legendFormat": "Failed logins",
          "refId": "F"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "none", "color": { "mode": "palette-classic" } },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "graphMode": "none",
        "colorMode": "value",
        "orientation": "horizontal"
      }
    },

    {
      "id": 30,
      "type": "row",
      "title": "ws-service (WebSocket / Realtime)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 38 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 31,
      "type": "stat",
      "title": "Connected Clients / Active Games",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 39 },
      "targets": [
        {
          "expr": "ws_connected_clients{service=\"ws-service\"}",
          "legendFormat": "Connected clients",
          "refId": "A"
        },
        {
          "expr": "ws_active_games{service=\"ws-service\"}",
          "legendFormat": "Active games",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "none", "color": { "mode": "palette-classic" } },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "graphMode": "area",
        "colorMode": "value"
      }
    },
    {
      "id": 32,
      "type": "timeseries",
      "title": "WS Messages Rate (received / sent)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 9, "x": 6, "y": 39 },
      "targets": [
        {
          "expr": "sum by (type) (rate(ws_messages_received_total{service=\"ws-service\"}[5m]))",
          "legendFormat": "received: {{type}}",
          "refId": "A"
        },
        {
          "expr": "sum by (type) (rate(ws_messages_sent_total{service=\"ws-service\"}[5m]))",
          "legendFormat": "sent: {{type}}",
          "refId": "B"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] }
    },
    {
      "id": 33,
      "type": "timeseries",
      "title": "Moves Validated vs Invalid",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 9, "x": 15, "y": 39 },
      "targets": [
        {
          "expr": "rate(ws_moves_validated_total{service=\"ws-service\"}[5m])",
          "legendFormat": "valid",
          "refId": "A"
        },
        {
          "expr": "rate(ws_invalid_moves_total{service=\"ws-service\"}[5m])",
          "legendFormat": "invalid",
          "refId": "B"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] }
    },
    {
      "id": 34,
      "type": "timeseries",
      "title": "Move Validation Latency (avg)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 7, "w": 8, "x": 0, "y": 47 },
      "targets": [
        {
          "expr": "rate(ws_move_validation_duration_seconds_sum{service=\"ws-service\"}[5m]) / rate(ws_move_validation_duration_seconds_count{service=\"ws-service\"}[5m])",
          "legendFormat": "avg validation time",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] }
    },
    {
      "id": 35,
      "type": "timeseries",
      "title": "Redis Publish Rate",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 7, "w": 8, "x": 8, "y": 47 },
      "targets": [
        {
          "expr": "rate(ws_events_published_total{service=\"ws-service\"}[5m])",
          "legendFormat": "events published",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] }
    },
    {
      "id": 36,
      "type": "timeseries",
      "title": "Redis Publish Latency (avg)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 7, "w": 8, "x": 16, "y": 47 },
      "targets": [
        {
          "expr": "rate(ws_redis_publish_duration_seconds_sum{service=\"ws-service\"}[5m]) / rate(ws_redis_publish_duration_seconds_count{service=\"ws-service\"}[5m])",
          "legendFormat": "avg publish time",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] }
    },

    {
      "id": 40,
      "type": "row",
      "title": "persistence-service (Storage / Consumer)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 54 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 41,
      "type": "stat",
      "title": "Games / Moves Persisted (totals)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 55 },
      "targets": [
        {
          "expr": "persistence_games_saved_total{service=\"persistence-service\"}",
          "legendFormat": "Games saved",
          "refId": "A"
        },
        {
          "expr": "persistence_games_completed_total{service=\"persistence-service\"}",
          "legendFormat": "Games completed",
          "refId": "B"
        },
        {
          "expr": "persistence_moves_saved_total{service=\"persistence-service\"}",
          "legendFormat": "Moves saved",
          "refId": "C"
        },
        {
          "expr": "persistence_events_consumed_total{service=\"persistence-service\"}",
          "legendFormat": "Events consumed",
          "refId": "D"
        },
        {
          "expr": "persistence_failed_events_total{service=\"persistence-service\"}",
          "legendFormat": "Failed events",
          "refId": "E"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "none", "color": { "mode": "palette-classic" } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Failed events" },
            "properties": [
              {
                "id": "color",
                "value": { "mode": "fixed", "fixedColor": "red" }
              }
            ]
          }
        ]
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "graphMode": "none",
        "colorMode": "value",
        "orientation": "horizontal"
      }
    },
    {
      "id": 42,
      "type": "timeseries",
      "title": "Redis Events Consumed Rate (by type)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 61 },
      "targets": [
        {
          "expr": "sum by (type) (rate(persistence_events_total{service=\"persistence-service\"}[5m]))",
          "legendFormat": "{{type}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] }
    },
    {
      "id": 43,
      "type": "timeseries",
      "title": "Outbound API Calls to api-service (rate, by endpoint/status)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 61 },
      "targets": [
        {
          "expr": "sum by (endpoint, status) (rate(persistence_api_calls_total{service=\"persistence-service\"}[5m]))",
          "legendFormat": "{{endpoint}} [{{status}}]",
          "refId": "A"
        },
        {
          "expr": "sum by (endpoint) (rate(persistence_api_failures_total{service=\"persistence-service\"}[5m]))",
          "legendFormat": "{{endpoint}} [failure]",
          "refId": "B"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] }
    },
    {
      "id": 44,
      "type": "timeseries",
      "title": "Outbound API Call Latency (avg, by endpoint)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 61 },
      "targets": [
        {
          "expr": "sum by (endpoint) (rate(persistence_api_duration_seconds_sum{service=\"persistence-service\"}[5m])) / sum by (endpoint) (rate(persistence_api_duration_seconds_count{service=\"persistence-service\"}[5m]))",
          "legendFormat": "{{endpoint}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] }
    },
    {
      "id": 45,
      "type": "timeseries",
      "title": "Persistence Save Latency (avg, by operation)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 69 },
      "targets": [
        {
          "expr": "sum by (operation) (rate(persistence_save_duration_seconds_sum{service=\"persistence-service\"}[5m])) / sum by (operation) (rate(persistence_save_duration_seconds_count{service=\"persistence-service\"}[5m]))",
          "legendFormat": "{{operation}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] }
    },
    {
      "id": 46,
      "type": "timeseries",
      "title": "Failed Event Processing Rate",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 69 },
      "targets": [
        {
          "expr": "rate(persistence_failed_events_total{service=\"persistence-service\"}[5m])",
          "legendFormat": "failed events",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "color": { "mode": "fixed", "fixedColor": "red" }
        },
        "overrides": []
      }
    }
  ]
}
